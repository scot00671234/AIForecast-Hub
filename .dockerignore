# Production build optimization
# Allow built assets for production deployment
!dist/
!dist/public/
!dist/public/*
!dist/index.js

# Block Caddy detection but allow our built static files
Caddyfile*
caddy.*
*.caddy
caddy/

# Force Node.js detection
!package.json
!package-lock.json
!*.js
!*.ts
!nixpacks.toml
!fix-build.js