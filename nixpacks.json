{
  "providers": ["node"],
  "buildCommand": "npm run build",
  "startCommand": "npm start",
  "staticAssets": {
    "enabled": false
  },
  "variables": {
    "NIXPACKS_NO_CADDY": "1",
    "DISABLE_CADDY": "1",
    "NO_CADDY": "1",
    "FORCE_NODE_ONLY": "1"
  },
  "buildOptions": {
    "disableCaddy": true,
    "disableStatic": true,
    "forceNodeOnly": true
  }
}