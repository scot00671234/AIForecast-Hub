:3000 {
        # Serve static files from dist/public with proper caching
        root * /app/dist/public
        
        # API routes - proxy to Node.js app on port 8080
        @api path /api/*
        reverse_proxy @api localhost:8080
        
        # For all other requests, try to serve files or fall back to index.html
        try_files {path} /index.html
        file_server
        
        # Add GZIP compression
        encode gzip
        
        # Cache headers for assets
        @assets path /assets/*
        header @assets Cache-Control "public, max-age=31536000, immutable"
        
        # No cache for index.html  
        @index path /index.html
        header @index Cache-Control "no-cache, no-store, must-revalidate"
        
        # Security headers
        header {
                X-Frame-Options DENY
                X-Content-Type-Options nosniff
                Referrer-Policy strict-origin-when-cross-origin
        }
}