:3000 {
	# Disable ALL caching completely
	header {
		# Remove any cache headers
		-Cache-Control
		-ETag 
		-Last-Modified
		-Expires
		
		# Add anti-cache headers
		Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
		Pragma "no-cache"
		Expires "-1"
		X-Cache-Disabled "true"
		X-Proxy-Cache "disabled"
	}
	
	# Reverse proxy to Node.js without any caching
	reverse_proxy localhost:3000 {
		# Disable buffering to prevent caching
		flush_interval -1
		
		# Pass through all headers
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		header_up X-Real-IP {remote}
	}
}