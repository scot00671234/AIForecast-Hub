# Caddy configuration to fix caching issues
{
    # Global options
    admin off
}

# Main site configuration
:3000 {
    # Reverse proxy to your Node.js app
    reverse_proxy localhost:3000 {
        # CRITICAL: Disable all caching at proxy level
        header_up Cache-Control "no-cache, no-store, must-revalidate"
        header_up Pragma "no-cache" 
        header_up Expires "0"
        
        # Pass through original headers
        header_down -Server
        header_down +X-Deployment-Fix "v1.0.1"
        header_down +X-Cache-Control "force-refresh"
    }
    
    # Force no caching for HTML files
    @html {
        path *.html /
    }
    header @html {
        Cache-Control "no-cache, no-store, must-revalidate"
        Pragma "no-cache"
        Expires "0"
        X-Deployment-Fix "v1.0.1"
    }
    
    # Force no caching for API endpoints
    @api {
        path /api/*
    }
    header @api {
        Cache-Control "no-cache, no-store, must-revalidate"
        Pragma "no-cache" 
        Expires "0"
    }
    
    # Moderate caching for static assets
    @static {
        path *.js *.css *.png *.jpg *.svg *.ico
    }
    header @static {
        Cache-Control "public, max-age=300, must-revalidate"
        X-Deployment-Fix "v1.0.1"
    }
    
    # Health check endpoint
    respond /health 200 {
        body "healthy - deployment fix v1.0.1"
    }
    
    # Log all requests for debugging
    log {
        output stdout
        format console
    }
}