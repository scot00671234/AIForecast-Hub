# Production Environment Variables for AIForecast Hub
# Copy this file to your production environment and update the values

# Application Configuration
NODE_ENV=production
PORT=5000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database

# Required API Keys for AI Models
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-claude-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Session Configuration
SESSION_SECRET=your-secure-session-secret-here

# Optional: Yahoo Finance API (for enhanced data fetching)
# YAHOO_FINANCE_API_KEY=your-yahoo-finance-api-key

# Optional: Rate Limiting Configuration
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Optional: Logging Configuration
# LOG_LEVEL=info
# ENABLE_ACCESS_LOGS=true